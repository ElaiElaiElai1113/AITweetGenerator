# AI Provider API Keys (choose one or more)
# Production: use server-side keys (no VITE_ prefix) with /api routes
# Local fallback (client direct) can still use VITE_ keys when needed

# GLM (Zhipu AI) - Vision support
# Get your key: https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=your_glm_api_key_here
VITE_GLM_API_KEY=

# Groq - Fast, free, unlimited (Recommended)
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_API_KEY=

# DeepSeek - Free tier available
# Get your key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
VITE_DEEPSEEK_API_KEY=

# OpenAI - GPT models (Paid, $5 free credit)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_API_KEY=

# Together AI - $25 free credit
# Get your key: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here
VITE_TOGETHER_API_KEY=

# HuggingFace - 30K free requests/month
# Get your key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
VITE_HUGGINGFACE_API_KEY=

# Google Gemini - Free tier available
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_API_KEY=

# Optional flags
# Force secure server endpoints even in local development
VITE_FORCE_SERVER_API=false
# Force direct client calls (development only)
VITE_FORCE_CLIENT_API=false


# Error Tracking (Optional)
# Get your DSN from: https://sentry.io/settings/projects/
# Leave empty to disable Sentry
VITE_SENTRY_DSN=

# Enable Sentry in development (default: false)
# Set to "true" to test Sentry locally
VITE_SENTRY_ENABLE_DEV=false
